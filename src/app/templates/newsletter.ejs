<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sustainify — Trending Ideas</title>
</head>
<body style="margin:0;padding:0;background-color:#0f172a;font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#0f172a;padding:40px 0;">
    <tr>
      <td align="center">

        <!-- Container -->
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#1e293b;border-radius:16px;overflow:hidden;box-shadow:0 25px 50px rgba(0,0,0,0.4);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#059669 0%,#10b981 50%,#34d399 100%);padding:40px 32px;text-align:center;">
              <h1 style="margin:0;font-size:28px;font-weight:700;color:#ffffff;letter-spacing:-0.5px;">
                🌱 Sustainify
              </h1>
              <p style="margin:8px 0 0;font-size:14px;color:rgba(255,255,255,0.85);font-weight:500;letter-spacing:1px;text-transform:uppercase;">
                Trending Ideas
              </p>
            </td>
          </tr>

          <!-- Intro -->
          <tr>
            <td style="padding:32px 32px 8px;">
              <p style="margin:0;font-size:16px;line-height:1.6;color:#94a3b8;">
                Here are the <strong style="color:#34d399;">top-rated sustainability ideas</strong> our community is buzzing about right now. Dive in and get inspired!
              </p>
            </td>
          </tr>

          <!-- Ideas List -->
          <tr>
            <td style="padding:16px 32px 32px;">
              <% if (ideas && ideas.length > 0) { %>
                <% ideas.forEach(function(idea, index) { %>
                  <!-- Idea Card -->
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:16px;">
                    <tr>
                      <td style="background-color:#0f172a;border-radius:12px;padding:20px 24px;border-left:4px solid #10b981;">
                        <!-- Score Badge & Title Row -->
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                          <tr>
                            <td width="56" valign="top">
                              <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#059669,#34d399);display:inline-block;text-align:center;line-height:48px;font-size:16px;font-weight:700;color:#ffffff;">
                                <%= idea.positiveRatio %>%
                              </div>
                            </td>
                            <td style="padding-left:12px;" valign="top">
                              <h2 style="margin:0 0 6px;font-size:17px;font-weight:600;color:#f1f5f9;line-height:1.3;">
                                <%= idea.title %>
                              </h2>
                              <p style="margin:0;font-size:13px;color:#64748b;line-height:1.5;">
                                <%= idea.problemStatement.length > 100 ? idea.problemStatement.substring(0, 100) + '...' : idea.problemStatement %>
                              </p>
                            </td>
                          </tr>
                        </table>

                        <!-- Stats & CTA -->
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:14px;">
                          <tr>
                            <td>
                              <span style="display:inline-block;background-color:#064e3b;color:#6ee7b7;font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;letter-spacing:0.5px;">
                                👍 <%= idea.totalUpVotes %> upvotes
                              </span>
                            </td>
                            <td align="right">
                              <a href="<%= frontendUrl %>/ideas" style="display:inline-block;background:linear-gradient(135deg,#059669,#10b981);color:#ffffff;text-decoration:none;font-size:12px;font-weight:600;padding:8px 18px;border-radius:8px;letter-spacing:0.3px;">
                                See More →
                              </a>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                <% }); %>
              <% } else { %>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="background-color:#0f172a;border-radius:12px;padding:32px;text-align:center;">
                      <p style="margin:0;font-size:15px;color:#64748b;">
                        No trending ideas at the moment. Check back soon! 🌿
                      </p>
                    </td>
                  </tr>
                </table>
              <% } %>
            </td>
          </tr>

          <!-- CTA Banner -->
          <tr>
            <td style="padding:0 32px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background:linear-gradient(135deg,#064e3b 0%,#065f46 100%);border-radius:12px;padding:24px;text-align:center;">
                    <p style="margin:0 0 14px;font-size:15px;color:#a7f3d0;font-weight:500;">
                      Want to explore all sustainability ideas?
                    </p>
                    <a href="<%= frontendUrl %>/ideas" style="display:inline-block;background:#ffffff;color:#059669;text-decoration:none;font-size:14px;font-weight:700;padding:12px 32px;border-radius:8px;letter-spacing:0.3px;">
                      Browse All Ideas 🚀
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 32px;border-top:1px solid #334155;text-align:center;">
              <p style="margin:0 0 8px;font-size:12px;color:#475569;">
                You are receiving this because you subscribed to the Sustainify newsletter.
              </p>
              <p style="margin:0;font-size:11px;color:#334155;">
                © <%= new Date().getFullYear() %> Sustainify. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
        <!-- /Container -->

      </td>
    </tr>
  </table>
  <!-- /Wrapper -->

</body>
</html>
