<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Medical Prescription</title>
</head>

<body style="margin:0;padding:0;background:#f4f6f9;font-family:Arial,Helvetica,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="padding:30px 0;">
<tr>
<td align="center">

<table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 4px 10px rgba(0,0,0,0.08);">

<!-- Header -->

<tr>
<td style="background:#0f766e;color:#ffffff;text-align:center;padding:25px;">
<h2 style="margin:0;font-size:24px;">Medical Prescription</h2>
<p style="margin:6px 0 0;font-size:14px;opacity:0.9;">Your prescription has been issued</p>
</td>
</tr>

<!-- Body -->

<tr>
<td style="padding:30px;">

<p style="font-size:16px;margin-bottom:20px;">
Dear <strong><%= patientName %></strong>,
</p>

<p style="font-size:15px;color:#444;line-height:1.6;">
Your doctor has issued a prescription after your consultation.  
Please review the prescription information below.
</p>

<!-- Prescription Info -->

<table width="100%" cellpadding="0" cellspacing="0" style="margin-top:25px;border:1px solid #e5e7eb;border-radius:6px;">
<tr>
<td colspan="2" style="padding:15px;background:#f9fafb;border-bottom:1px solid #e5e7eb;">
<strong>Prescription Details</strong>
</td>
</tr>

<tr>
<td style="padding:12px;font-size:14px;color:#444;"><strong>Prescription ID</strong></td>
<td style="padding:12px;font-size:14px;color:#444;"><%= prescriptionId %></td>
</tr>

<tr style="background:#fafafa;">
<td style="padding:12px;font-size:14px;color:#444;"><strong>Issue Date</strong></td>
<td style="padding:12px;font-size:14px;color:#444;"><%= issueDate %></td>
</tr>

<tr>
<td style="padding:12px;font-size:14px;color:#444;"><strong>Appointment Date</strong></td>
<td style="padding:12px;font-size:14px;color:#444;"><%= appointmentDate %></td>
</tr>

<tr style="background:#fafafa;">
<td style="padding:12px;font-size:14px;color:#444;"><strong>Follow Up Date</strong></td>
<td style="padding:12px;font-size:14px;color:#444;"><%= followUpDate %></td>
</tr>

</table>

<!-- Doctor Info -->

<table width="100%" cellpadding="0" cellspacing="0" style="margin-top:20px;border:1px solid #e5e7eb;border-radius:6px;">
<tr>
<td style="padding:15px;background:#f9fafb;border-bottom:1px solid #e5e7eb;">
<strong>Doctor Information</strong>
</td>
</tr>

<tr>
<td style="padding:15px;font-size:14px;color:#444;">
<p style="margin:4px 0;"><strong>Doctor Name:</strong> <%= doctorName %></p>
<p style="margin:4px 0;"><strong>Specialization:</strong> <%= specialization %></p>
</td>
</tr>
</table>

<!-- Instructions -->

<table width="100%" cellpadding="0" cellspacing="0" style="margin-top:20px;border:1px solid #e5e7eb;border-radius:6px;">
<tr>
<td style="padding:15px;background:#f9fafb;border-bottom:1px solid #e5e7eb;">
<strong>Doctor Instructions</strong>
</td>
</tr>

<tr>
<td style="padding:15px;font-size:14px;color:#444;line-height:1.6;">
<%= instructions %>
</td>
</tr>
</table>

<!-- Button -->

<table width="100%" cellpadding="0" cellspacing="0" style="margin-top:30px;text-align:center;">
<tr>
<td>

<a href="<%= pdfUrl %>"
style="display:inline-block;background:#0f766e;color:#ffffff;padding:12px 24px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:bold;">
Download Prescription PDF </a>

</td>
</tr>
</table>

<p style="margin-top:30px;font-size:14px;color:#666;">
If you have questions regarding your prescription, please contact your healthcare provider.
</p>

</td>
</tr>

<!-- Footer -->

<tr>
<td style="background:#f9fafb;text-align:center;padding:20px;font-size:13px;color:#777;">
<p style="margin:0;">This email was automatically generated by the Medical System.</p>
<p style="margin:4px 0 0;">Please do not reply to this email.</p>
</td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>
