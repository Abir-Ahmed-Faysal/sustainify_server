model Payment {
    id String @id @default(uuid(7))

    appointmentId      String        @unique
    appointment        Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    amount             Float
    transitionId       String        @unique @db.Uuid()
    stripeEventId      String?       @unique
    paymentGatewayData Json?
    invoiceUrl         String?
    status             PaymentStatus @default(UNPAID)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([appointmentId], name: "idx_payment_appointmentId")
    @@index([transitionId], name: "idx_payment_transitionId")
    @@map("payments")
}
