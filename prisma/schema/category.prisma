model Category {
  id    String  @id @default(uuid())
  image String?
  name  String  @unique

  ideas Idea[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([id], name: "idx_category_id")
  @@index([name], name: "idx_category_name")
  @@map("categories")
}
