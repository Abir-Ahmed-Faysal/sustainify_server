model Access {
  id      String @id @default(uuid())
  userId  String
  ideaId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  idea    Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, ideaId])
  @@index([userId], name: "idx_access_userId")
  @@index([ideaId], name: "idx_access_ideaId")
  @@map("accesses")
}
