enum VoteType {
  UP
  DOWN
}

model Vote {
  id      String   @id @default(uuid())
  userId  String
  ideaId  String
  type    VoteType

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  idea    Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, ideaId])
  @@index([userId], name: "idx_vote_userId")
  @@index([ideaId], name: "idx_vote_ideaId")
}
